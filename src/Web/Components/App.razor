@inject AuthenticationStateProvider AuthProvider
@inject IUserService Users

<!DOCTYPE html>
<html lang="en" data-theme="@_theme">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="icon" href="favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="favicon.ico" sizes="32x32" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Scrobblint.Web.styles.css"]" />
    <HeadOutlet />
</head>

<body data-enhance-nav="false">
    <Routes />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    // Drives the colour theme: "system" (follow the OS), "light", or "dark".
    private string _theme = "system";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        if (state.User.GetUserId() is { } userId)
        {
            var settings = await Users.GetSettingsAsync(userId);
            if (settings.Succeeded)
                _theme = settings.Value!.Theme.ToString().ToLowerInvariant();
        }
    }
}
