@* Size: "sm" (42 px) | "md" (64 px) | "lg" (96 px) *@
<div class="art-thumb art-thumb-@Size art-placeholder" aria-hidden="true">
    <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
        <rect width="100" height="100" fill="var(--panel)"/>
        <!-- vinyl disc -->
        <circle cx="50" cy="50" r="46" fill="#181310"/>
        <!-- subtle highlight shimmer -->
        <ellipse cx="33" cy="21" rx="13" ry="7" fill="#2e2622" opacity="0.7" transform="rotate(-35 33 21)"/>
        <!-- groove rings -->
        <circle cx="50" cy="50" r="42" fill="none" stroke="#2a231e" stroke-width="0.8"/>
        <circle cx="50" cy="50" r="38" fill="none" stroke="#2a231e" stroke-width="0.8"/>
        <circle cx="50" cy="50" r="34" fill="none" stroke="#2a231e" stroke-width="0.8"/>
        <circle cx="50" cy="50" r="30" fill="none" stroke="#2a231e" stroke-width="0.8"/>
        <circle cx="50" cy="50" r="26" fill="none" stroke="#2a231e" stroke-width="0.8"/>
        <!-- center label -->
        <circle cx="50" cy="50" r="19" fill="var(--violet)"/>
        <!-- center hole -->
        <circle cx="50" cy="50" r="3.5" fill="#181310"/>
    </svg>
</div>

@code {
    [Parameter] public string Size { get; set; } = "sm";
}
