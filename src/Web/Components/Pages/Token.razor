@page "/settings/token"
@attribute [Authorize]
@inject IAuthService Auth

<PageTitle>API token — Scrobblint</PageTitle>

<h1>Settings</h1>

<SettingsNav />

<div class="card narrow">
    <p>Use this token to submit scrobbles. Send it in the <code>Authorization</code> header:</p>
    <pre class="code-block">Authorization: Token @(_token ?? "…")</pre>

    <label>
        Token
        <input class="token-field" value="@_token" readonly />
    </label>

    <form method="post" action="/account/token/regenerate" onsubmit="return confirm('Regenerate your token? The current one will stop working.');">
        <AntiforgeryToken />
        <button class="btn btn-danger" type="submit">Regenerate token</button>
    </form>
    <p class="muted">Regenerating immediately invalidates the previous token.</p>
</div>

<div class="card">
    <h2>Example: submit a scrobble (native API)</h2>
    <pre class="code-block">curl -X POST @(_baseUrl)/api/scrobble \
  -H "Authorization: Token @(_token ?? "YOUR_TOKEN")" \
  -H "Content-Type: application/json" \
  -d '{"artist":"Radiohead","track":"Idioteque","album":"Kid A"}'</pre>
</div>

<div class="card">
    <h2>Example: ListenBrainz-compatible API</h2>
    <p>Point any ListenBrainz client at <code>@_baseUrl</code> to use it as a drop-in replacement.</p>
    <pre class="code-block">curl -X POST @(_baseUrl)/1/submit-listens \
  -H "Authorization: Token @(_token ?? "YOUR_TOKEN")" \
  -H "Content-Type: application/json" \
  -d '{
  "listen_type": "single",
  "payload": [{
    "listened_at": 1706000000,
    "track_metadata": {
      "artist_name": "Radiohead",
      "track_name": "Idioteque",
      "release_name": "Kid A"
    }
  }]
}'</pre>
    <p class="muted">Supported listen types: <code>single</code>, <code>import</code>, <code>playing_now</code>. The <code>listened_at</code> field is a Unix timestamp (seconds); omit it for <code>playing_now</code>.</p>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private string? _token;
    private string _baseUrl = "";

    protected override async Task OnInitializedAsync()
    {
        _baseUrl = Navigation.BaseUri.TrimEnd('/');
        var user = (await AuthState!).User;
        var result = await Auth.GetTokenAsync(user.GetUserId()!.Value);
        if (result.Succeeded) _token = result.Value!.Token;
    }
}
