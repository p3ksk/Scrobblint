@page "/user/{Username}"
@inject IUserService Users
@inject IScrobbleService Scrobbles
@inject Scrobblint.Application.Abstractions.CoverArt.ICoverArtProvider CoverArt

<PageTitle>@Username — Scrobblint</PageTitle>

@if (_loaded && _profile is null)
{
    <div class="card">
        <h1>@(_forbidden ? "Private profile" : "User not found")</h1>
        <p class="muted">
            @(_forbidden
                ? "This user's profile is private."
                : $"No user named \"{Username}\" exists.")
        </p>
        <a class="btn" href="/">Home</a>
    </div>
}
else if (_profile is not null)
{
    <div class="profile-header">
        <h1>@_profile.Username @if (_profile.IsAdmin) { <span class="badge">admin</span> }</h1>
        <p class="muted">Member since @Format.DateUtc(_profile.CreatedAt) · @_profile.TotalScrobbles scrobbles</p>
    </div>

    @if (_nowPlaying is { } np)
    {
        <div class="card">
            <h2>Now playing</h2>
            <div class="now-playing-card">
                @if (_nowPlayingImage is not null)
                {
                    <img src="@_nowPlayingImage" class="art-thumb art-thumb-lg" alt="" />
                }
                <div>
                    <p class="track-line"><span class="track">@np.Track</span> — <a href="/artist/@Uri.EscapeDataString(np.Artist)" class="artist">@np.Artist</a></p>
                    @if (np.Album is not null)
                    {
                        <p class="muted">Album: <a href="/album/@Uri.EscapeDataString(np.Artist)/@Uri.EscapeDataString(np.Album)" class="muted">@np.Album</a></p>
                    }
                </div>
            </div>
        </div>
    }
    else if (_profile.LatestScrobble is { } latest)
    {
        <div class="card">
            <h2>Now / last played</h2>
            <div class="now-playing-card">
                @if (_latestImage is not null)
                {
                    <img src="@_latestImage" class="art-thumb art-thumb-lg" alt="" />
                }
                <div>
                    <p class="track-line"><span class="track">@latest.Track</span> — <a href="/artist/@Uri.EscapeDataString(latest.Artist)" class="artist">@latest.Artist</a></p>
                    <p class="muted">@Format.Ago(latest.Timestamp)</p>
                </div>
            </div>
        </div>
    }

    @if (_recent is { Items.Count: > 0 })
    {
        <div class="card">
            <h2>Recent listens</h2>
            <ul class="scrobble-list">
                @foreach (var s in _recent.Items)
                {
                    <li>
                        @if (s.Album is not null && _recentAlbumCovers.TryGetValue(s.Id, out var coverUrl) && coverUrl is not null)
                        {
                            <img src="@coverUrl" class="art-thumb art-thumb-sm" alt="" />
                        }
                        <span class="track">@s.Track</span>
                        <a href="/artist/@Uri.EscapeDataString(s.Artist)" class="artist">@s.Artist</a>
                        <span class="time">@Format.Ago(s.Timestamp)</span>
                    </li>
                }
            </ul>
        </div>
    }
}

@code {
    [Parameter] public string Username { get; set; } = "";
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private UserProfileResponse? _profile;
    private PagedResponse<ScrobbleResponse>? _recent;
    private NowPlayingResponse? _nowPlaying;
    private string? _nowPlayingImage;
    private string? _latestImage;
    private Dictionary<Guid, string?> _recentAlbumCovers = new();
    private bool _loaded;
    private bool _forbidden;

    protected override async Task OnInitializedAsync()
    {
        var viewer = ViewerContext.Anonymous;
        if (AuthState is not null)
        {
            var user = (await AuthState).User;
            if (user.Identity?.IsAuthenticated == true)
                viewer = new ViewerContext(user.GetUserId(), user.IsAdmin());
        }

        var profile = await Users.GetProfileAsync(Username, viewer);
        if (profile.Succeeded)
        {
            _profile = profile.Value;
            var recent = await Scrobbles.GetRecentAsync(Username, 1, 10, viewer);
            if (recent.Succeeded) _recent = recent.Value;
            _nowPlaying = await Scrobbles.GetNowPlayingByUsernameAsync(Username);
        }
        else
        {
            _forbidden = profile.Error == ResultError.Forbidden;
        }
        _loaded = true;

        // Resolve artwork in parallel.
        Task<string?>? nowPlayingTask = null;
        Task<string?>? latestTask = null;
        Dictionary<Guid, Task<string?>>? albumTasks = null;

        if (_nowPlaying is not null && !string.IsNullOrEmpty(_nowPlaying.Album))
            nowPlayingTask = CoverArt.GetAlbumCoverUrlAsync(_nowPlaying.Artist, _nowPlaying.Album);
        else if (_profile?.LatestScrobble is { } latest && !string.IsNullOrEmpty(latest.Album))
            latestTask = CoverArt.GetAlbumCoverUrlAsync(latest.Artist, latest.Album);

        if (_recent?.Items is { Count: > 0 } recentItems)
        {
            albumTasks = recentItems
                .Where(s => !string.IsNullOrEmpty(s.Album))
                .ToDictionary(s => s.Id, s => CoverArt.GetAlbumCoverUrlAsync(s.Artist, s.Album!));
        }

        var tasks = new List<Task>();
        if (nowPlayingTask is not null) tasks.Add(nowPlayingTask);
        if (latestTask is not null) tasks.Add(latestTask);
        if (albumTasks is not null) tasks.AddRange(albumTasks.Values);

        if (tasks.Count > 0)
            await Task.WhenAll(tasks);

        _nowPlayingImage = nowPlayingTask?.Result;
        _latestImage = latestTask?.Result;

        if (albumTasks is not null)
        {
            foreach (var kvp in albumTasks)
                _recentAlbumCovers[kvp.Key] = kvp.Value.Result;
        }
    }
}
