@page "/dashboard"
@attribute [Authorize]
@inject IStatisticsService Stats
@inject IScrobbleService Scrobbles
@inject Scrobblint.Application.Abstractions.CoverArt.ICoverArtProvider CoverArt

<PageTitle>Dashboard — Scrobblint</PageTitle>

<h1>Dashboard</h1>

@if (_stats is null)
{
    <p>Loading…</p>
}
else
{
    <div class="stat-grid">
        <div class="stat-card"><span class="stat-num">@_stats.TotalScrobbles</span><span class="stat-label">Scrobbles</span></div>
        <div class="stat-card"><span class="stat-num">@_stats.UniqueArtists</span><span class="stat-label">Artists</span></div>
        <div class="stat-card"><span class="stat-num">@_stats.UniqueTracks</span><span class="stat-label">Tracks</span></div>
    </div>

    @if (_nowPlaying is not null)
    {
        <div class="card">
            <h2>Now playing</h2>
            <div class="now-playing-card">
                @if (_nowPlayingImage is not null)
                {
                    <img src="@_nowPlayingImage" class="art-thumb art-thumb-lg" alt="" />
                }
                <div>
                    <p class="track-line"><span class="track">@_nowPlaying.Track</span> — <a href="/artist/@Uri.EscapeDataString(_nowPlaying.Artist)" class="artist">@_nowPlaying.Artist</a></p>
                    @if (_nowPlaying.Album is not null)
                    {
                        <p class="muted">Album: @_nowPlaying.Album</p>
                    }
                </div>
            </div>
        </div>
    }

    <div class="grid-2">
        <div class="card">
            <h2>Recent listens</h2>
            @if (_recent is { Items.Count: > 0 })
            {
                <ul class="scrobble-list">
                    @foreach (var s in _recent.Items)
                    {
                        <li>
                            @if (s.Album is not null && _recentAlbumCovers.TryGetValue(s.Id, out var coverUrl) && coverUrl is not null)
                            {
                                <img src="@coverUrl" class="art-thumb art-thumb-sm" alt="" />
                            }
                            <span class="track">@s.Track</span>
                            <a href="/artist/@Uri.EscapeDataString(s.Artist)" class="artist">@s.Artist</a>
                            <span class="time">@Format.Ago(s.Timestamp)</span>
                        </li>
                    }
                </ul>
                <a href="/recent">See all recent →</a>
            }
            else
            {
                <p class="muted">No scrobbles yet. Submit some via the API — see your <a href="/settings/token">token</a>.</p>
            }
        </div>

        <div class="card">
            <h2>Top artists</h2>
            @if (_stats.TopArtists.Count > 0)
            {
                <ol class="rank-list">
                    @foreach (var a in _stats.TopArtists)
                    {
                        <li>
                            @if (_artistImages.TryGetValue(a.Artist, out var imgUrl) && imgUrl is not null)
                            {
                                <img src="@imgUrl" class="art-thumb art-thumb-sm" alt="" />
                            }
                            <a href="/artist/@Uri.EscapeDataString(a.Artist)" class="rank-link">@a.Artist</a><span class="count">@a.Count</span>
                        </li>
                    }
                </ol>
                <a href="/stats">Full statistics →</a>
            }
            else
            {
                <p class="muted">Nothing to chart yet.</p>
            }
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private StatsResponse? _stats;
    private PagedResponse<ScrobbleResponse>? _recent;
    private NowPlayingResponse? _nowPlaying;
    private string? _nowPlayingImage;
    private Dictionary<string, string?> _artistImages = new();
    private Dictionary<Guid, string?> _recentAlbumCovers = new();

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthState!).User;
        var username = user.GetUsername()!;
        var viewer = new ViewerContext(user.GetUserId(), user.IsAdmin());

        var stats = await Stats.GetStatsAsync(username, viewer);
        if (stats.Succeeded) _stats = stats.Value;

        var recent = await Scrobbles.GetRecentAsync(username, 1, 5, viewer);
        if (recent.Succeeded) _recent = recent.Value;

        _nowPlaying = Scrobbles.GetNowPlaying(user.GetUserId()!.Value);

        // Resolve artwork in parallel (all cached after the first hit).
        Task<string?>? nowPlayingTask = null;
        if (_nowPlaying is not null && !string.IsNullOrEmpty(_nowPlaying.Album))
            nowPlayingTask = CoverArt.GetAlbumCoverUrlAsync(_nowPlaying.Artist, _nowPlaying.Album);

        Dictionary<string, Task<string?>>? artistTasks = null;
        if (_stats?.TopArtists is { Count: > 0 } topArtists)
            artistTasks = topArtists.ToDictionary(a => a.Artist, a => CoverArt.GetArtistImageUrlAsync(a.Artist));

        Dictionary<Guid, Task<string?>>? albumTasks = null;
        if (_recent?.Items is { Count: > 0 } recentItems)
        {
            albumTasks = recentItems
                .Where(s => !string.IsNullOrEmpty(s.Album))
                .ToDictionary(s => s.Id, s => CoverArt.GetAlbumCoverUrlAsync(s.Artist, s.Album!));
        }

        // Collect all tasks and await once.
        var allTasks = new List<Task>();
        if (nowPlayingTask is not null) allTasks.Add(nowPlayingTask);
        if (artistTasks is not null) allTasks.AddRange(artistTasks.Values);
        if (albumTasks is not null) allTasks.AddRange(albumTasks.Values);
        await Task.WhenAll(allTasks);

        _nowPlayingImage = nowPlayingTask?.Result;

        if (artistTasks is not null)
        {
            foreach (var kvp in artistTasks)
                _artistImages[kvp.Key] = kvp.Value.Result;
        }

        if (albumTasks is not null)
        {
            foreach (var kvp in albumTasks)
                _recentAlbumCovers[kvp.Key] = kvp.Value.Result;
        }
    }
}
