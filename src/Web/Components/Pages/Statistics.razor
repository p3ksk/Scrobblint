@page "/stats"
@attribute [Authorize]
@inject IStatisticsService Stats
@inject Scrobblint.Application.Abstractions.CoverArt.ICoverArtProvider CoverArt

<PageTitle>Statistics — Scrobblint</PageTitle>

<h1>Statistics</h1>

<div class="card">
    <nav class="settings-nav" aria-label="Date range presets">
        <a class='settings-tab @PresetClass(IsAllTime)' href="@RangeHref(null, null)">All time</a>
        <a class='settings-tab @PresetClass(IsLast7)' href="@RangeHref(SevenDaysAgo, Today)">Last 7 days</a>
        <a class='settings-tab @PresetClass(IsLast30)' href="@RangeHref(ThirtyDaysAgo, Today)">Last 30 days</a>
        <a class='settings-tab @PresetClass(IsThisYear)' href="@RangeHref(ThisYearStart, Today)">This year</a>
        <a class='settings-tab @PresetClass(IsLastYear)' href="@RangeHref(LastYearStart, LastYearEnd)">Last year</a>
    </nav>
    <form method="get" action="/stats" class="filter-form">
        @if (_tab is not null)
        {
            <input type="hidden" name="tab" value="@_tab" />
        }
        <label>From <input type="date" name="from" value="@_fromParam" /></label>
        <label>To <input type="date" name="to" value="@_toParam" /></label>
        <button type="submit" class="btn btn-primary">Apply</button>
        @if (!IsAllTime)
        {
            <a class="btn" href="@RangeHref(null, null)">Clear</a>
        }
    </form>
</div>

@if (_stats is null)
{
    <p>Loading…</p>
}
else
{
    <div class="stat-grid">
        <div class="stat-card"><span class="stat-num">@_stats.TotalScrobbles</span><span class="stat-label">Total scrobbles</span></div>
        <div class="stat-card"><span class="stat-num">@_stats.UniqueArtists</span><span class="stat-label">Unique artists</span></div>
        <div class="stat-card"><span class="stat-num">@_stats.UniqueTracks</span><span class="stat-label">Unique tracks</span></div>
        <div class="stat-card"><span class="stat-num">@_stats.UniqueAlbums</span><span class="stat-label">Unique albums</span></div>
    </div>

    <div class="grid-3">
        <div class="card">
            <h2>Top artists</h2>
            <ol class="rank-list">
                @foreach (var a in _stats.TopArtists)
                {
                    <li>
                        @if (_artistImages.TryGetValue(a.Artist, out var imgUrl) && imgUrl is not null)
                        {
                            <img src="@imgUrl" class="art-thumb art-thumb-sm" alt="" />
                        }
                        <a href="/artist/@Uri.EscapeDataString(a.Artist)" class="rank-link">@a.Artist</a><span class="count">@a.Count</span>
                    </li>
                }
            </ol>
        </div>
        <div class="card">
            <h2>Top albums</h2>
            <ol class="rank-list">
                @foreach (var a in _stats.TopAlbums)
                {
                    <li>
                        @if (_albumImages.TryGetValue($"{a.Artist}::{a.Album}", out var coverUrl) && coverUrl is not null)
                        {
                            <img src="@coverUrl" class="art-thumb art-thumb-sm" alt="" />
                        }
                        <a href="/album/@Uri.EscapeDataString(a.Artist)/@Uri.EscapeDataString(a.Album)" class="rank-link">@a.Album <span class="muted">— @a.Artist</span></a><span class="count">@a.Count</span>
                    </li>
                }
            </ol>
        </div>
        <div class="card">
            <h2>Top tracks</h2>
            <ol class="rank-list">
                @foreach (var t in _stats.TopTracks)
                {
                    <li><span>@t.Track <span class="muted">— @t.Artist</span></span><span class="count">@t.Count</span></li>
                }
            </ol>
        </div>
    </div>

    <div class="card">
        <nav class="settings-nav" aria-label="Charts">
            <a class='settings-tab @TabClass("monthly")' href="/stats?@ChartTabQuery("monthly")">Monthly</a>
            <a class='settings-tab @TabClass("daily")' href="/stats?@ChartTabQuery("daily")">Daily</a>
            <a class='settings-tab @TabClass("hourly")' href="/stats?@ChartTabQuery("hourly")">Hourly</a>
            <a class='settings-tab @TabClass("weekly")' href="/stats?@ChartTabQuery("weekly")">Day of week</a>
            <a class='settings-tab @TabClass("yearly")' href="/stats?@ChartTabQuery("yearly")">Yearly</a>
        </nav>

        @switch (_tab ?? "monthly")
        {
            case "monthly":
                <h2>Monthly chart</h2>
                @RenderBars(MonthlyPageItems)
                @if (MonthlyTotalPages > 1)
                {
                    <div class="pager">
                        @if (_monthlyPage > 0)
                        {
                            <a class="btn" href="/stats?@ChartTabQuery("monthly", _monthlyPage - 1)">← Previous</a>
                        }
                        else
                        {
                            <span class="btn" disabled aria-disabled="true">← Previous</span>
                        }
                        <span>Page @(_monthlyPage + 1) of @MonthlyTotalPages</span>
                        @if (_monthlyPage < MonthlyTotalPages - 1)
                        {
                            <a class="btn" href="/stats?@ChartTabQuery("monthly", _monthlyPage + 1)">Next →</a>
                        }
                        else
                        {
                            <span class="btn" disabled aria-disabled="true">Next →</span>
                        }
                    </div>
                }
                break;
            case "daily":
                <h2>Daily chart @(IsAllTime ? "(last 30 days)" : $"({_fromParam} – {_toParam ?? Today})")</h2>
                @RenderBars(_stats.DailyChart)
                break;
            case "hourly":
                <h2>Hourly chart</h2>
                @RenderBars(_stats.HourlyChart)
                break;
            case "weekly":
                <h2>Day of week</h2>
                @RenderBars(_stats.DayOfWeekChart)
                break;
            case "yearly":
                <h2>Yearly chart</h2>
                @RenderBars(_stats.YearlyChart)
                break;
        }
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    [SupplyParameterFromQuery(Name = "tab")] private string? _tab { get; set; }
    [SupplyParameterFromQuery(Name = "monthlyPage")] private int _monthlyPage { get; set; }
    [SupplyParameterFromQuery(Name = "from")] private string? _fromParam { get; set; }
    [SupplyParameterFromQuery(Name = "to")] private string? _toParam { get; set; }

    private StatsResponse? _stats;
    private Dictionary<string, string?> _artistImages = new();
    private Dictionary<string, string?> _albumImages = new();
    private const int MonthlyPageSize = 12;

    // Preset date strings (UTC)
    private static string Today => DateTime.UtcNow.Date.ToString("yyyy-MM-dd");
    private static string SevenDaysAgo => DateTime.UtcNow.Date.AddDays(-7).ToString("yyyy-MM-dd");
    private static string ThirtyDaysAgo => DateTime.UtcNow.Date.AddDays(-30).ToString("yyyy-MM-dd");
    private static string ThisYearStart => new DateTime(DateTime.UtcNow.Year, 1, 1).ToString("yyyy-MM-dd");
    private static string LastYearStart => new DateTime(DateTime.UtcNow.Year - 1, 1, 1).ToString("yyyy-MM-dd");
    private static string LastYearEnd => new DateTime(DateTime.UtcNow.Year - 1, 12, 31).ToString("yyyy-MM-dd");

    // Active preset detection
    private bool IsAllTime => _fromParam is null && _toParam is null;
    private bool IsLast7 => _fromParam == SevenDaysAgo && _toParam == Today;
    private bool IsLast30 => _fromParam == ThirtyDaysAgo && _toParam == Today;
    private bool IsThisYear => _fromParam == ThisYearStart && _toParam == Today;
    private bool IsLastYear => _fromParam == LastYearStart && _toParam == LastYearEnd;

    // Parsed UTC bounds passed to the service (to is exclusive end-of-day)
    private DateTime? FromUtc => ParseDateParam(_fromParam);
    private DateTime? ToUtc => ParseDateParam(_toParam)?.AddDays(1);

    private static DateTime? ParseDateParam(string? s) =>
        !string.IsNullOrEmpty(s) && DateTime.TryParseExact(s, "yyyy-MM-dd", null,
            System.Globalization.DateTimeStyles.None, out var d)
            ? DateTime.SpecifyKind(d, DateTimeKind.Utc)
            : null;

    private string RangeHref(string? from, string? to)
    {
        var parts = new List<string>();
        if (_tab is not null) parts.Add($"tab={_tab}");
        if (from is not null) parts.Add($"from={from}");
        if (to is not null) parts.Add($"to={to}");
        return parts.Count > 0 ? "/stats?" + string.Join("&", parts) : "/stats";
    }

    private string ChartTabQuery(string tab, int? monthlyPage = null)
    {
        var parts = new List<string> { $"tab={tab}" };
        if (_fromParam is not null) parts.Add($"from={_fromParam}");
        if (_toParam is not null) parts.Add($"to={_toParam}");
        if (monthlyPage is not null) parts.Add($"monthlyPage={monthlyPage}");
        return string.Join("&", parts);
    }

    private string PresetClass(bool active) => active ? "active" : "";
    private string TabClass(string tab) => (_tab ?? "monthly") == tab ? "active" : "";

    private int MonthlyTotalPages => _stats is null ? 0 : (int)Math.Ceiling(_stats.MonthlyChart.Count / (double)MonthlyPageSize);

    private IReadOnlyList<ChartPoint> MonthlyPageItems
    {
        get
        {
            if (_stats is null || MonthlyTotalPages == 0) return Array.Empty<ChartPoint>();
            var page = Math.Clamp(_monthlyPage, 0, MonthlyTotalPages - 1);
            var reversed = _stats.MonthlyChart.Reverse().ToList();
            return reversed.Skip(page * MonthlyPageSize).Take(MonthlyPageSize).ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthState!).User;
        var viewer = new ViewerContext(user.GetUserId(), user.IsAdmin());
        var result = await Stats.GetStatsAsync(user.GetUsername()!, viewer, FromUtc, ToUtc);
        if (result.Succeeded) _stats = result.Value;

        if (_stats is null) return;

        // Resolve artwork in parallel.
        Dictionary<string, Task<string?>>? artistTasks = null;
        if (_stats.TopArtists is { Count: > 0 } topArtists)
            artistTasks = topArtists.ToDictionary(a => a.Artist, a => CoverArt.GetArtistImageUrlAsync(a.Artist));

        Dictionary<string, Task<string?>>? albumTasks = null;
        if (_stats.TopAlbums is { Count: > 0 } topAlbums)
            albumTasks = topAlbums.ToDictionary(a => $"{a.Artist}::{a.Album}", a => CoverArt.GetAlbumCoverUrlAsync(a.Artist, a.Album));

        var tasks = new List<Task>();
        if (artistTasks is not null) tasks.AddRange(artistTasks.Values);
        if (albumTasks is not null) tasks.AddRange(albumTasks.Values);

        if (tasks.Count > 0)
            await Task.WhenAll(tasks);

        if (artistTasks is not null)
        {
            foreach (var kvp in artistTasks)
                _artistImages[kvp.Key] = kvp.Value.Result;
        }

        if (albumTasks is not null)
        {
            foreach (var kvp in albumTasks)
                _albumImages[kvp.Key] = kvp.Value.Result;
        }
    }

    private RenderFragment RenderBars(IReadOnlyList<ChartPoint> points) => builder =>
    {
        if (points.Count == 0)
        {
            builder.AddMarkupContent(0, "<p class=\"muted\">No data yet.</p>");
            return;
        }

        var max = points.Max(p => p.Count);
        builder.OpenElement(1, "div");
        builder.AddAttribute(2, "class", "bar-chart");
        var seq = 3;
        foreach (var p in points)
        {
            var pct = max == 0 ? 0 : (int)Math.Round(p.Count * 100.0 / max);
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "bar-row");

            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "bar-label");
            builder.AddContent(seq++, p.Period);
            builder.CloseElement();

            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "bar-track");
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "bar-fill");
            builder.AddAttribute(seq++, "style", $"width:{pct}%");
            builder.CloseElement();
            builder.CloseElement();

            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "bar-value");
            builder.AddContent(seq++, p.Count);
            builder.CloseElement();

            builder.CloseElement();
        }
        builder.CloseElement();
    };
}
