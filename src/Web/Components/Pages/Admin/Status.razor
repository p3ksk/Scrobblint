@page "/admin/status"
@attribute [Authorize(Roles = "Admin")]
@inject IAdminService Admin

<PageTitle>Status — Scrobblint</PageTitle>

<h1>Status</h1>

@if (_status is null)
{
    <p>Loading…</p>
}
else
{
    <div class="detail-list" style="max-width:600px">
        <dt>Uptime</dt>
        <dd>@FormatUptime(_status.UptimeSeconds)</dd>

        <dt>Memory (working set)</dt>
        <dd>@_status.WorkingSetMb MB</dd>

        <dt>Memory (GC heap)</dt>
        <dd>@_status.GcHeapMb MB</dd>

        <dt>Thread pool threads</dt>
        <dd>@_status.ThreadPoolThreads</dd>

        <dt>Users</dt>
        <dd>@_status.TotalUsers</dd>

        <dt>Total scrobbles</dt>
        <dd>@_status.TotalScrobbles</dd>

        <dt>Relay queue</dt>
        <dd>@_status.RelayQueueDepth</dd>

        <dt>Import queue</dt>
        <dd>@_status.ImportQueueDepth</dd>

        <dt>Cover art cache entries</dt>
        <dd>@_status.CoverArtEntries</dd>

        <dt>Cover art cache hits</dt>
        <dd>@_status.CoverArtCacheHits</dd>

        <dt>Cover art cache misses</dt>
        <dd>@_status.CoverArtCacheMisses</dd>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private AdminStatus? _status;

    protected override async Task OnInitializedAsync()
    {
        _status = await Admin.GetStatusAsync();
    }

    private static string FormatUptime(long seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        var parts = new List<string>();
        if (ts.Days > 0) parts.Add($"{ts.Days}d");
        if (ts.Hours > 0) parts.Add($"{ts.Hours}h");
        if (ts.Minutes > 0) parts.Add($"{ts.Minutes}m");
        if (parts.Count == 0) parts.Add("0m");
        return string.Join(" ", parts);
    }
}
