@page "/admin/trackcache"
@attribute [Authorize(Roles = "Admin")]
@inject ITrackInfoRepository TrackInfo

<PageTitle>Track Cache — Scrobblint</PageTitle>

<AdminNav />
<h1>Track cache</h1>

<div class="card">
    @if (DeletedAll is > 0)
    {
        <div class="alert alert-success">@DeletedAll entry(ies) deleted.</div>
    }

    <div class="action-row">
        <form method="get" action="/admin/trackcache" class="search-form">
            <input name="search" value="@Search" placeholder="Search artist or track…" />
            <button class="btn" type="submit">Search</button>
            @if (!string.IsNullOrWhiteSpace(Search))
            {
                <a class="btn" href="/admin/trackcache">Clear</a>
            }
        </form>
        <form method="post" action="/admin/trackcache/delete-all"
              onsubmit="return confirm('Delete ALL track cache entries? The cache will repopulate as scrobbles come in.');">
            <AntiforgeryToken />
            <button class="btn btn-danger" type="submit">Remove all</button>
        </form>
    </div>

    @if (_items is null)
    {
        <p>Loading…</p>
    }
    else
    {
        <div class="table-scroll">
        <table class="table">
            <thead>
                <tr><th>Submitted artist</th><th>Submitted track</th><th>Canonical artist</th><th>Canonical track</th><th>Canonical album</th><th>Found</th><th>Fetched</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var t in _items)
                {
                    <tr>
                        <td>@t.ArtistKey</td>
                        <td>@t.TrackKey</td>
                        <td>@(t.CanonicalArtist ?? "—")</td>
                        <td>@(t.CanonicalTrack ?? "—")</td>
                        <td>@(t.CanonicalAlbum ?? "—")</td>
                        <td>
                            @if (t.Found)
                            {
                                <span class="badge badge-ok">found</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">miss</span>
                            }
                        </td>
                        <td class="muted">@t.FetchedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td><a href="/admin/trackcache/@t.Id">Edit</a></td>
                    </tr>
                }
            </tbody>
        </table>
        </div>

        <div class="pager">
            @if (_page > 1)
            {
                <a class="btn" href="/admin/trackcache?page=@(_page - 1)&search=@Search">← Previous</a>
            }
            <span class="muted">Page @_page of @_totalPages (@_total entries)</span>
            @if (_page < _totalPages)
            {
                <a class="btn" href="/admin/trackcache?page=@(_page + 1)&search=@Search">Next →</a>
            }
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery] private int? Page { get; set; }
    [SupplyParameterFromQuery] private string? Search { get; set; }
    [SupplyParameterFromQuery] private int? DeletedAll { get; set; }

    private IReadOnlyList<TrackInfo>? _items;
    private int _page = 1;
    private int _total;
    private int _totalPages;

    protected override async Task OnInitializedAsync()
    {
        _page = Math.Max(1, Page ?? 1);
        var (items, total) = await TrackInfo.ListAsync(_page, 25, Search);
        _items = items;
        _total = total;
        _totalPages = Math.Max(1, (int)Math.Ceiling(_total / 25.0));
    }
}
