@page "/settings/connections"
@attribute [Authorize]
@using Scrobblint.Shared.Connections
@inject IExternalConnectionService ConnectionService
@inject IScrobbleImportService ImportService

<PageTitle>Connections — Scrobblint</PageTitle>

<h1>Settings</h1>

<SettingsNav />

<p class="muted">Relay every listen you submit to Scrobblint onward to these services.</p>

@if (!string.IsNullOrEmpty(Error))
{
    <div class="alert alert-error">@Error</div>
}
else if (Saved == 1)
{
    <div class="alert alert-success">Connection updated.</div>
}
else if (Retried == 1)
{
    <div class="alert alert-success">Relay reset — it will be retried shortly.</div>
}
else if (Deleted == 1)
{
    <div class="alert alert-success">Retry cache record deleted.</div>
}

@if (_data is null)
{
    <p>Loading…</p>
}
else
{
    @* ---- ListenBrainz ---- *@
    <div class="card narrow">
        <h2>ListenBrainz</h2>
        @{ var lb = Find(ScrobbleProvider.ListenBrainz); }
        @if (lb is not null)
        {
            <p>
                Connected as <strong>@(lb.ExternalUsername ?? "your account")</strong>
                @if (lb.IsEnabled) { <span class="badge badge-ok">relaying</span> } else { <span class="badge">paused</span> }
            </p>
            @if (!string.IsNullOrEmpty(lb.ApiRoot)) { <p class="muted">Instance: @lb.ApiRoot</p> }
            <div class="action-row">
                <form method="post" action="/account/connections/listenbrainz/toggle">
                    <AntiforgeryToken />
                    <input type="hidden" name="enabled" value="@((!lb.IsEnabled).ToString().ToLower())" />
                    <button class="btn" type="submit">@(lb.IsEnabled ? "Pause" : "Resume")</button>
                </form>
                <form method="post" action="/account/connections/listenbrainz/disconnect">
                    <AntiforgeryToken />
                    <button class="btn btn-danger" type="submit">Disconnect</button>
                </form>
            </div>
        }
        else
        {
            <form method="post" action="/account/connections/listenbrainz">
                <AntiforgeryToken />
                <label>User token
                    <input name="token" required placeholder="from listenbrainz.org/profile" />
                </label>
                <label>Instance API root (optional)
                    <input name="apiRoot" placeholder="https://api.listenbrainz.org" />
                </label>
                <button class="btn btn-primary" type="submit">Connect ListenBrainz</button>
            </form>
        }
    </div>

    @* ---- Last.fm ---- *@
    <div class="card narrow">
        <h2>Last.fm</h2>
        @{ var fm = Find(ScrobbleProvider.Lastfm); }
        @if (!_data.LastfmAvailable && fm is null)
        {
            <p class="muted">Last.fm relaying is not configured on this server (no API key/secret).</p>
        }
        else if (fm is not null)
        {
            <p>
                Connected as <strong>@(fm.ExternalUsername ?? "your account")</strong>
                @if (fm.IsEnabled) { <span class="badge badge-ok">relaying</span> } else { <span class="badge">paused</span> }
            </p>
            <div class="action-row">
                <form method="post" action="/account/connections/lastfm/toggle">
                    <AntiforgeryToken />
                    <input type="hidden" name="enabled" value="@((!fm.IsEnabled).ToString().ToLower())" />
                    <button class="btn" type="submit">@(fm.IsEnabled ? "Pause" : "Resume")</button>
                </form>
                <form method="post" action="/account/connections/lastfm/disconnect">
                    <AntiforgeryToken />
                    <button class="btn btn-danger" type="submit">Disconnect</button>
                </form>
            </div>
        }
        else
        {
            <p class="muted">You'll be sent to Last.fm to authorize Scrobblint. Your password is never shared with this server.</p>
            <form method="post" action="/account/connections/lastfm/start">
                <AntiforgeryToken />
                <button class="btn btn-primary" type="submit">Authorize with Last.fm</button>
            </form>
        }
    </div>

    @* ---- Last.fm history import ---- *@
    @if (Find(ScrobbleProvider.Lastfm) is not null)
    {
        @if (_import is { IsActive: true })
        {
            <HeadContent>
                <meta http-equiv="refresh" content="5" />
            </HeadContent>
        }

        <div class="card narrow">
            <h2>Import Last.fm history</h2>
            @if (_import is { IsActive: true })
            {
                <p><strong>@_import.ImportedCount.ToString("N0")</strong> scrobbles imported so far@(_import.DuplicateCount > 0 ? $" ({_import.DuplicateCount:N0} already present)" : "").</p>
                @if (_import.TotalPages > 0)
                {
                    <div class="bar-track"><span class="bar-fill" style="width:@(_import.PercentComplete ?? 0)%"></span></div>
                    <p class="muted">
                        ~@_import.TotalAvailable.ToString("N0") total · page @(Math.Max(0, _import.Page - 1)) of @_import.TotalPages.ToString("N0") · @(_import.PercentComplete ?? 0)%
                    </p>
                }
                else
                {
                    <p class="muted">Contacting Last.fm…</p>
                }
                <form method="post" action="/account/connections/lastfm/import/cancel">
                    <AntiforgeryToken />
                    <button class="btn btn-danger" type="submit">Cancel import</button>
                </form>
                <p class="muted">Runs in the background — you can leave this page. It refreshes every few seconds.</p>
            }
            else
            {
                @if (_import is not null)
                {
                    <p>
                        Last import: <strong>@_import.Status.ToLowerInvariant()</strong> —
                        @_import.ImportedCount.ToString("N0") imported, @_import.DuplicateCount.ToString("N0") duplicates.
                    </p>
                    @if (!string.IsNullOrEmpty(_import.Error))
                    {
                        <div class="alert alert-error">@_import.Error</div>
                    }
                }
                <p class="muted">
                    Pull your entire Last.fm scrobble history into Scrobblint. Large libraries (100k+) take a while —
                    it runs in the background and is safe to re-run (duplicates are skipped).
                </p>
                <form method="post" action="/account/connections/lastfm/import">
                    <AntiforgeryToken />
                    <button class="btn btn-primary" type="submit">@(_import is null ? "Import history" : "Re-import history")</button>
                </form>
            }
        </div>
    }

    @* ---- Stuck relays ---- *@
    @if (_failedRelays is { Count: > 0 })
    {
        <div class="card narrow">
            <h2>Failed relays</h2>
            <p class="muted">Listens that couldn't be relayed on to a service. Retry will re-attempt on the next worker poll.</p>
            <div class="table-scroll">
            <table class="table">
                <thead>
                    <tr><th>Provider</th><th>Status</th><th>Tracks</th><th>Retries</th><th>Last error</th><th>Updated</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var r in _failedRelays)
                    {
                        <tr>
                            <td>@r.Provider</td>
                            <td>@r.Status</td>
                            <td>@r.TrackCount</td>
                            <td>@r.RetryCount</td>
                            <td class="muted">@(r.LastError ?? "—")</td>
                            <td class="muted">@Format.DateTimeUtc(r.UpdatedAt)</td>
                            <td>
                                <div class="action-row">
                                    <form method="post" action="/account/relayretries/@r.Id/retry">
                                        <AntiforgeryToken />
                                        <button class="btn" type="submit">Retry</button>
                                    </form>
                                    <form method="post" action="/account/relayretries/@r.Id/delete"
                                          onsubmit="return confirm('Give up on this relay? This cannot be undone.');">
                                        <AntiforgeryToken />
                                        <button class="btn btn-danger" type="submit">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>
    }
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    [SupplyParameterFromQuery] private string? Error { get; set; }
    [SupplyParameterFromQuery] private int? Saved { get; set; }
    [SupplyParameterFromQuery] private int? Retried { get; set; }
    [SupplyParameterFromQuery] private int? Deleted { get; set; }

    private ConnectionsResponse? _data;
    private ImportStatusDto? _import;
    private IReadOnlyList<UserFailedRelayDto>? _failedRelays;

    protected override async Task OnInitializedAsync()
    {
        var userId = (await AuthState!).User.GetUserId()!.Value;
        var result = await ConnectionService.GetConnectionsAsync(userId);
        if (result.Succeeded) _data = result.Value;
        _import = await ImportService.GetStatusAsync(userId);

        var failedRelays = await ConnectionService.GetFailedRelaysAsync(userId);
        if (failedRelays.Succeeded) _failedRelays = failedRelays.Value;
    }

    private ExternalConnectionDto? Find(ScrobbleProvider provider) =>
        _data?.Connections.FirstOrDefault(c => c.Provider == provider);
}
