@inject AuthenticationStateProvider AuthProvider

<nav class="navbar">
    <a class="brand" href="/">🎧 Scrobblint</a>
    <div class="nav-links">
        <AuthorizeView>
            <Authorized>
                <a href="/dashboard">Dashboard</a>
                <a href="/recent">Recent</a>
                <a href="/stats">Statistics</a>
                <a href="/settings">Settings</a>
                <AuthorizeView Roles="Admin" Context="admin">
                    <a href="/admin/status">Status</a>
                    <a href="/admin/users">Users</a>
                </AuthorizeView>
                <span class="nav-user">@context.User.Identity?.Name</span>
                <form method="post" action="/account/logout" class="inline-form">
                    <AntiforgeryToken />
                    <button type="submit" class="btn btn-link">Log out</button>
                </form>
            </Authorized>
            <NotAuthorized>
                <a href="/login">Login</a>
                <a href="/register">Register</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</nav>
